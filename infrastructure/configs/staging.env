# =============================================================================
# Gastropilot Staging Environment
# =============================================================================

STACK_NAME=gastropilot-staging

# Domains
FRONTEND_DOMAIN=staging.gastropilot.app
BACKEND_DOMAIN=api-staging.gastropilot.app
API_URL=https://api-staging.gastropilot.app

# Database
POSTGRES_USER=gastropilot
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
POSTGRES_DB=gastropilot_staging
DATABASE_URL=postgresql://gastropilot:CHANGE_ME_STAGING_DB_PASSWORD@postgres:5432/gastropilot_staging

# Security
JWT_SECRET=CHANGE_ME_STAGING_JWT_SECRET
SECRET_KEY=CHANGE_ME_STAGING_SECRET_KEY

# CORS
CORS_ORIGINS=https://staging.gastropilot.app

# Optional
SENTRY_DSN=
