# Environment Configuration
ENV=development

# Database
DATABASE_URL=sqlite+aiosqlite:///./reservation_dev.db
# For PostgreSQL/Neon:
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/database?sslmode=require
DATABASE_TYPE=neon

# JWT / Security
JWT_SECRET=your-secret-key-change-in-production-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ISSUER=reservation-app
JWT_AUDIENCE=reservation-api
JWT_LEEWAY_SECONDS=10
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password hashing
BCRYPT_ROUNDS=12

# CORS Configuration
# Füge die IP-Adresse deines Servers hinzu, damit iPad/Tablet-Zugriff funktioniert
# Port 3001 = GastroPilot Frontend, Port 3002 = Reservation Widget
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002,http://192.168.178.24:3001,http://192.168.178.24:3002
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,Accept,Accept-Language,Cache-Control,X-Requested-With

# Server
# Füge die IP-Adresse deines Servers hinzu
# Für Production: Füge auch die Domain hinzu (z.B. api.gastropilot.org)
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.178.24,api.gastropilot.org

# Logging
LOG_LEVEL=INFO

# License / Feature Management
LICENSE_KEY=your-license-key-here
MOTHERSHIP_URL=https://mothership.servecta.com
LICENSE_CHECK_INTERVAL=3600
LICENSE_CHECK_TIMEOUT=5

# AI / OpenAI Configuration
AI_ENABLED=false
OPENAI_API_KEY=sk-your-openai-api-key
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.3

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+49123456789
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=reservierung@gastropilot.org

# Public Booking
PUBLIC_BOOKING_ENABLED=false
PUBLIC_BOOKING_DEFAULT_DURATION=120
RESERVATION_WIDGET_URL=https://reservierung.gastropilot.org

# SumUp Payment Integration
# Diese Werte werden serverseitig verwaltet und sind NICHT im Frontend konfigurierbar
SUMUP_API_KEY=sk_test_your_sumup_api_key_here
SUMUP_MERCHANT_CODE=your_merchant_code_here
# Webhook Secret: Wird von SumUp beim Einrichten des Webhooks bereitgestellt
# Finden Sie es im SumUp Developer Portal unter "Webhooks" oder kontaktieren Sie den SumUp Support
SUMUP_WEBHOOK_SECRET=your_webhook_secret_here
SUMUP_WEBHOOK_URL=https://api.gastropilot.org/v1/webhooks/sumup
# Testmodus: true = Checkout ohne Reader (für Entwicklung), false = Reader Checkout (für Produktion)
SUMUP_TEST_MODE=true
