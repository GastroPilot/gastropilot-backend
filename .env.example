# ===========================================
# GastroPilot Backend – Umgebungsvariablen
# ===========================================
# Kopieren nach .env und Werte anpassen

# Umgebung
# --------
# Optionen: development, staging, production, test
ENV=development

# Datenbank
# ---------
# PostgreSQL (asyncpg fuer Microservices)
DATABASE_URL=postgresql+asyncpg://gastropilot_app:gastropilot_app_password@postgres:5432/gastropilot
DATABASE_ADMIN_URL=postgresql+asyncpg://gastropilot_admin:gastropilot_admin_password@postgres:5432/gastropilot

# JWT / Sicherheit
# ----------------
# Generieren mit: openssl rand -hex 32
JWT_SECRET=aendern-in-produktion-mindestens-32-zeichen-lang
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
# -----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS
# ----
# Kommagetrennte Liste erlaubter Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
# -------
# Optionen: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─── Externe Dienste (optional) ──────────────────────────────────────────────

# Payments – SumUp
# SUMUP_API_KEY=
# SUMUP_MERCHANT_CODE=
# SUMUP_WEBHOOK_SECRET=

# Payments – Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# fiskaly KassenSichV / TSE
# API-Zugangsdaten aus dem fiskaly Dashboard: https://dashboard.fiskaly.com
# FISKALY_API_KEY=
# FISKALY_API_SECRET=
# FISKALY_BASE_URL=https://kassensichv-middleware.fiskaly.com/api/v2
# FISKALY_TEST_MODE=true

# OpenAI API
# OPENAI_API_KEY=sk-...

# Twilio (SMS + WhatsApp)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Sentry Error Tracking
# SENTRY_DSN=

# E-Mail (SMTP)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# fiskaly KassenSichV / TSE (optional)
# API-Zugangsdaten aus dem fiskaly Dashboard: https://dashboard.fiskaly.com
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_BASE_URL=https://kassensichv-middleware.fiskaly.com/api/v2
FISKALY_TEST_MODE=true
