# ===========================================
# Gastropilot Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Environment
# -----------
# Options: development, staging, production, test
ENV=development

# Database
# --------
# PostgreSQL connection string
# For local development with Docker: postgresql://postgres:postgres@localhost:5432/gastropilot_dev
# For SQLite (development only): sqlite+aiosqlite:///./gastropilot.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gastropilot_dev

# Security
# --------
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
SECRET_KEY=change-me-in-production

# CORS
# ----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Logging
# -------
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# External Services (Optional)
# ----------------------------

# OpenAI API
# OPENAI_API_KEY=sk-...

# Twilio (SMS + WhatsApp)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Sentry Error Tracking
# SENTRY_DSN=

# Email Configuration
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
