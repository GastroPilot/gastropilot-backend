# Notifications Service – Umgebungsvariablen
ENVIRONMENT=development

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# E-Mail (smtp oder resend)
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@gastropilot.de

# Alternativ: Resend
RESEND_API_KEY=

# SMS (optional)
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Push (Expo)
PUSH_ENABLED=true
EXPO_ACCESS_TOKEN=
