# Orders Service – Umgebungsvariablen
# Kopieren nach .env und Werte anpassen
ENV=development

# Datenbank
DATABASE_URL=postgresql+asyncpg://gastropilot_app:gastropilot_app_password@postgres:5432/gastropilot
DATABASE_ADMIN_URL=postgresql+asyncpg://gastropilot_admin:gastropilot_admin_password@postgres:5432/gastropilot

# JWT
JWT_SECRET=aendern-in-produktion-mindestens-32-zeichen-lang
JWT_ALGORITHM=HS256

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS
# Bei Zugriff vom Handy/LAN zusaetzlich die eigene IP ergaenzen, z. B. http://192.168.178.57:8081
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3004,http://127.0.0.1:3004,http://localhost:8081,http://127.0.0.1:8081

# SumUp (optional)
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=
SUMUP_WEBHOOK_SECRET=

# fiskaly KassenSichV / TSE (optional)
# API-Zugangsdaten aus dem fiskaly Dashboard: https://dashboard.fiskaly.com
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_BASE_URL=https://kassensichv-middleware.fiskaly.com/api/v2
FISKALY_TEST_MODE=true
