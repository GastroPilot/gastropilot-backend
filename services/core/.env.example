# Core Service – Umgebungsvariablen
# Kopieren nach .env und Werte anpassen

ENV=development
SEED_ON_STARTUP=false

# Datenbank
DATABASE_URL=postgresql+asyncpg://gastropilot_app:gastropilot_app_password@postgres:5432/gastropilot
DATABASE_ADMIN_URL=postgresql+asyncpg://gastropilot_admin:gastropilot_admin_password@postgres:5432/gastropilot

# JWT
JWT_SECRET=aendern-in-produktion-mindestens-32-zeichen-lang
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Web-Frontend Origins, die NUR E-Mail/Passwort Login nutzen dürfen (kein PIN/NFC)
WEB_PASSWORD_ONLY_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://gpilot.app,https://www.gpilot.app,https://demo.gpilot.app,https://www.demo.gpilot.app,https://staging.gpilot.app,https://www.staging.gpilot.app,https://test.gpilot.app,https://www.test.gpilot.app

# Payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=

# Sentry (optional)
SENTRY_DSN=
